modules = ["nodejs-24", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[userenv]

[userenv.shared]
DEMO_MODE = "true"
ADMIN_SECRET = "nutritest-admin-2026"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 24170
externalPort = 3000

[[ports]]
localPort = 24171
externalPort = 4200


[postMerge]
path = "Family-Nutrition-Planner/scripts/post-merge.sh"
timeoutMs = 300000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Family-Nutrition-Planner && DEMO_MODE=true PORT=5000 API_PORT=8080 pnpm --filter @workspace/nutrinext run dev"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "start.mjs"]
build = ["bash", "build.sh"]
