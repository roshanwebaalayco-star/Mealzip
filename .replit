modules = ["nodejs-20", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
integrations = ["javascript_gemini_ai_integrations:2.0.0"]

[userenv]

[userenv.shared]
JWT_SECRET = "2e612f0f617094ec9b7dd866abeaf9ac8ff685930af9ca014a0601d6e8f53fa01a79794b8cfdffc0b58a26712f5863d17e11be2271a926064f53aad9f49a21d2"
DEMO_MODE = "true"

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 24170
externalPort = 3000

[[ports]]
localPort = 24171
externalPort = 3001

[postMerge]
path = "Family-Nutrition-Planner/scripts/post-merge.sh"
timeoutMs = 300000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Family-Nutrition-Planner && PORT=3000 DEMO_MODE=true pnpm --filter @workspace/api-server run dev & PORT=5000 API_PORT=3000 pnpm --filter @workspace/nutrinext run dev & wait"
waitForPort = 5000
