# ─────────────────────────────────────────────
# ParivarSehat AI — Required Environment Variables
# Copy this file to .env and fill in real values.
# In production, set these directly in Replit Secrets.
# ─────────────────────────────────────────────

# PostgreSQL connection string provided by Replit Managed DB
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini AI API key — https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Sarvam AI key for voice transcription (Hindi/regional) — https://sarvam.ai
SARVAM_API_KEY=sk_...

# Node environment: "development" or "production"
NODE_ENV=development

# ─────────────────────────────────────────────
# Optional — set to enable features
# ─────────────────────────────────────────────

# YOLOv11 inference server URL for food scanner (leave blank to run in demo mode)
# YOLOV11_INFERENCE_URL=http://localhost:9000/infer

# Enable demo mode — scanner returns simulated data instead of calling YOLO
# DEMO_MODE=true

# Admin email for seeding via POST /api/admin/seed in production
# ADMIN_EMAIL=admin@yourdomain.com

# ─────────────────────────────────────────────
# Google OAuth (optional — app uses JWT auth by default)
# ─────────────────────────────────────────────
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
