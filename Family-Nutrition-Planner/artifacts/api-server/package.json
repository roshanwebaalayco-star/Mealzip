    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "natural": "^8.1.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
